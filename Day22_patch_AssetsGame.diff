diff --git a/Assets/_Game/Jobs/Executors/RepairWorkExecutor.cs b/Assets/_Game/Jobs/Executors/RepairWorkExecutor.cs
new file mode 100644
index 0000000..2bed843
--- /dev/null
+++ b/Assets/_Game/Jobs/Executors/RepairWorkExecutor.cs
@@ -0,0 +1,108 @@
+using System.Collections.Generic;
+using SeasonalBastion.Contracts;
+
+namespace SeasonalBastion
+{
+    /// <summary>
+    /// VS2 Day22: Repair work executor (minimal).
+    /// - Move NPC to building anchor.
+    /// - Consume time (dt) and restore HP in fixed chunks.
+    /// - No resource consumption yet (plan allows time-only minimal).
+    /// </summary>
+    public sealed class RepairWorkExecutor : IJobExecutor
+    {
+        private readonly GameServices _s;
+
+        // runtime-only progress
+        private readonly Dictionary<int, float> _workByJob = new();
+
+        // deliverable C (locked): RepairWorkChunkTime=4s, RepairRestoresPctPerChunk=15%
+        private const float ChunkSeconds = 4f;
+        private const int HealPctPerChunk = 15;
+
+        public RepairWorkExecutor(GameServices s) { _s = s; }
+
+        public bool Tick(NpcId npc, ref NpcState npcState, ref Job job, float dt)
+        {
+            if (_s.WorldState == null || _s.AgentMover == null)
+            {
+                job.Status = JobStatus.Failed;
+                _workByJob.Remove(job.Id.Value);
+                return true;
+            }
+
+            var bid = job.DestBuilding;
+            if (bid.Value == 0 || !_s.WorldState.Buildings.Exists(bid))
+            {
+                job.Status = JobStatus.Cancelled;
+                _workByJob.Remove(job.Id.Value);
+                return true;
+            }
+
+            var bs = _s.WorldState.Buildings.Get(bid);
+
+            // Defensive fix-up (older saves / older states)
+            if (bs.MaxHP <= 0)
+            {
+                int max = 100;
+                try { max = _s.DataRegistry.GetBuilding(bs.DefId).MaxHp; } catch { }
+                bs.MaxHP = max <= 0 ? 100 : max;
+                if (bs.HP <= 0) bs.HP = bs.MaxHP;
+                _s.WorldState.Buildings.Set(bid, bs);
+            }
+
+            // Early-out: already full
+            if (bs.HP >= bs.MaxHP)
+            {
+                job.Status = JobStatus.Completed;
+                _workByJob.Remove(job.Id.Value);
+                return true;
+            }
+
+            // Move to anchor (deterministic grid step)
+            var target = bs.Anchor;
+            if (npcState.Cell.X != target.X || npcState.Cell.Y != target.Y)
+            {
+                bool arrived = _s.AgentMover.StepToward(ref npcState, target);
+                job.Status = JobStatus.InProgress;
+                return true; // progressed (moved)
+            }
+
+            // Work on repair
+            job.Status = JobStatus.InProgress;
+            if (dt < 0f) dt = 0f;
+
+            float acc = 0f;
+            _workByJob.TryGetValue(job.Id.Value, out acc);
+            acc += dt;
+
+            if (acc >= ChunkSeconds)
+            {
+                // Apply whole chunks
+                int chunks = (int)(acc / ChunkSeconds);
+                acc -= chunks * ChunkSeconds;
+
+                // ceil(MaxHP * 15%) with integer math
+                int healPerChunk = (bs.MaxHP * HealPctPerChunk + 99) / 100;
+                if (healPerChunk < 1) healPerChunk = 1;
+
+                int newHp = bs.HP + healPerChunk * chunks;
+                if (newHp >= bs.MaxHP)
+                {
+                    bs.HP = bs.MaxHP;
+                    _s.WorldState.Buildings.Set(bid, bs);
+
+                    job.Status = JobStatus.Completed;
+                    _workByJob.Remove(job.Id.Value);
+                    return true;
+                }
+
+                bs.HP = newHp;
+                _s.WorldState.Buildings.Set(bid, bs);
+            }
+
+            _workByJob[job.Id.Value] = acc;
+            return true;
+        }
+    }
+}
