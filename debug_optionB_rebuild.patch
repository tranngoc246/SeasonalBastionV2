--- a/Debug/_Core/DebugRoot.cs+++ b/Debug/_Core/DebugRoot.cs@@ -0,0 +1,78 @@+using System.Collections.Generic;
+using UnityEngine;
+
+namespace SeasonalBastion.DebugTools
+{
+    /// <summary>
+    /// Debug root: auto-registers modules under this hierarchy and ticks enabled modules.
+    /// Attach this to a single Debug GameObject.
+    /// </summary>
+    public sealed class DebugRoot : MonoBehaviour
+    {
+        [SerializeField] private GameBootstrap _bootstrap;
+
+        private readonly List<IDebugModule> _modules = new List<IDebugModule>(64);
+        private DebugContext _ctx;
+
+        public DebugContext Ctx => _ctx;
+        public IReadOnlyList<IDebugModule> Modules => _modules;
+
+        private void Awake()
+        {
+            if (_bootstrap == null) _bootstrap = FindObjectOfType<GameBootstrap>();
+            _ctx = new DebugContext(_bootstrap);
+
+            CollectModules();
+        }
+
+        private void CollectModules()
+        {
+            _modules.Clear();
+
+            // include inactive children so you can keep modules disabled by default
+            var behaviours = GetComponentsInChildren<MonoBehaviour>(true);
+            for (int i = 0; i < behaviours.Length; i++)
+            {
+                if (behaviours[i] is IDebugModule m)
+                {
+                    m.Bind(_ctx);
+                    _modules.Add(m);
+                }
+            }
+
+            _modules.Sort((a, b) =>
+            {
+                int p = a.Priority.CompareTo(b.Priority);
+                if (p != 0) return p;
+                return string.CompareOrdinal(a.Title, b.Title);
+            });
+        }
+
+        private void Update()
+        {
+            _ctx.Refresh();
+
+            // tick enabled modules (tools/hud/gizmos may opt in)
+            float dt = Time.unscaledDeltaTime;
+            if (dt <= 0f) return;
+
+            for (int i = 0; i < _modules.Count; i++)
+            {
+                var m = _modules[i];
+                if (!m.IsEnabled) continue;
+                m.Tick(dt);
+            }
+        }
+
+        private void OnDrawGizmos()
+        {
+            if (_modules == null) return;
+            for (int i = 0; i < _modules.Count; i++)
+            {
+                var m = _modules[i];
+                if (!m.IsEnabled) continue;
+                m.DrawGizmos();
+            }
+        }
+    }
+}
--- a/Debug/_Core/DebugInputRouter.cs+++ b/Debug/_Core/DebugInputRouter.cs@@ -0,0 +1,36 @@+using UnityEngine;
+using UnityEngine.InputSystem;
+
+namespace SeasonalBastion.DebugTools
+{
+    /// <summary>Central hotkey router for DebugHUDHub. Tools should NOT own InputActions.</summary>
+    public sealed class DebugInputRouter
+    {
+        // Hub hotkeys
+        public Key ToggleUiKey = Key.F1;
+        public Key ModeBuildKey = Key.F2;
+        public Key ModeRoadKey = Key.F3;
+        public Key ModeNpcKey = Key.F4;
+        public Key ModeStorageKey = Key.F5;
+        public Key TabNotiKey = Key.F6;
+        public Key TabWorldIndexKey = Key.F7;
+        public Key ClearModeKey = Key.Escape;
+
+        public void TickHotkeys(DebugHUDHub hub)
+        {
+            var kb = Keyboard.current;
+            if (kb == null || hub == null) return;
+
+            if (kb[ToggleUiKey].wasPressedThisFrame) hub.ToggleUI();
+            if (kb[ClearModeKey].wasPressedThisFrame) hub.SetMode(DebugHubMode.None);
+
+            if (kb[ModeBuildKey].wasPressedThisFrame) hub.SetMode(DebugHubMode.Build);
+            if (kb[ModeRoadKey].wasPressedThisFrame) hub.SetMode(DebugHubMode.Road);
+            if (kb[ModeNpcKey].wasPressedThisFrame) hub.SetMode(DebugHubMode.Npc);
+            if (kb[ModeStorageKey].wasPressedThisFrame) hub.SetMode(DebugHubMode.Storage);
+
+            if (kb[TabNotiKey].wasPressedThisFrame) hub.SetTab(DebugHubTab.Notifications);
+            if (kb[TabWorldIndexKey].wasPressedThisFrame) hub.SetTab(DebugHubTab.WorldIndex);
+        }
+    }
+}
